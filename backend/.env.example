# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workeros
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploy
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=change_this_to_another_random_64_char_string
REFRESH_TOKEN_EXPIRES_IN=30d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:5173
