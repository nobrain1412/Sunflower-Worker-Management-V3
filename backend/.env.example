# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workeros
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploy
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=change_this_to_another_random_64_char_string
REFRESH_TOKEN_EXPIRES_IN=30d

# Upload — giới hạn file size
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:5173

# Cloudinary — lưu trữ ảnh (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OCR CCCD — FPT AI Inference / Marketplace (thay cho FPT.AI Vision cũ đã ngừng)
# Nền tảng OpenAI-compatible, dùng model Vision (Qwen2.5-VL) đọc ảnh CCCD → JSON.
# Đăng ký: https://marketplace.fptcloud.com → tạo API Key (cấp quyền model Qwen2.5-VL-7B-Instruct)
#          → NẠP BALANCE > 0 (trả theo token). Copy key dán vào đây.
# Nếu để trống HOẶC gọi lỗi, hệ thống fallback sang Tesseract.js (chính xác thấp ~30-50%).
FPT_AI_API_KEY=
# (tùy chọn) override endpoint & model — mặc định đã đúng, chỉ đổi khi cần:
# FPT_AI_BASE_URL=https://mkp-api.fptcloud.com/chat/completions
# FPT_AI_MODEL=Qwen2.5-VL-7B-Instruct

# OCR fallback — Tesseract.js (miễn phí, chạy local, không cần API key)
# Language data tự động download lần đầu vào thư mục /tmp/tessdata
