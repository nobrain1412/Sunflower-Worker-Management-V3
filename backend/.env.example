# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workeros
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploy
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=change_this_to_another_random_64_char_string
REFRESH_TOKEN_EXPIRES_IN=30d

# Upload — giới hạn file size
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:5173

# Cloudinary — lưu trữ ảnh (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OCR CCCD — FPT.AI (khuyến nghị, ~95-99% chính xác cho CCCD VN, trả JSON parsed sẵn)
# Đăng ký tại https://fpt.ai → tạo app → copy api-key
# Nếu để trống, hệ thống sẽ fallback sang Tesseract.js (chính xác thấp ~30-50%)
FPT_AI_API_KEY=

# OCR fallback — Tesseract.js (miễn phí, chạy local, không cần API key)
# Language data tự động download lần đầu vào thư mục /tmp/tessdata
